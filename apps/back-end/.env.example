PORT=4000
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgres://app:app@localhost:5432/meme_arena
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
UPLOADS_DIR=./uploads

# Google sign-in (optional — omit to hide the "Continue with Google" button)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# SMTP (optional — omit and password-reset emails are logged instead of sent)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=Meme Battle Arena <no-reply@meme-battle-arena.local>
